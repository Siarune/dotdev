{
	"linter": {
		"enabled": true,
		"ignore": [
			"node_modules",
			".*",
			"*.json",
			"README.md",
			"LICENSE",
			"*.lock",
			"*.log",
			"*.yml"
		],
		"rules": {
			"a11y": {
				"useValidAnchor": "off"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"ignore": [
			"node_modules",
			"README.md",
			"LICENSE",
			"*.json",
			"*.lock",
			"*.log",
			"*.yml",
			".*"
		],
		"indentStyle": "tab",
		"indentSize": 4,
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"quoteProperties": "asNeeded",
			"trailingComma": "all"
		}
	}
}
