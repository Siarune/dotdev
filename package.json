    "blitz": "2.0.0-beta.16",
    "date-fns": "^2.29.3",
    "final-form": "4.20.7",
    "next": "12.2.5",
    "prisma": "4.0.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-final-form": "6.5.9",
    "react-markdown": "^8.0.3",
    "sass": "1.55.0",
    "vercel": "^28.4.14",
    "zod": "3.17.3"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "12.0.8",
