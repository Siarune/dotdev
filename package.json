{
	"name": "siarune.dev",
	"packageManager": "yarn@3.2.4",
	"version": "1.0.0",
	"license": "GPLv3",
	"scripts": {
		"dev": "blitz dev",
		"build": "blitz build",
		"start": "blitz start",
		"studio": "blitz prisma studio",
		"lint": "eslint --ignore-path .gitignore --ext .js,.ts,.tsx .",
		"prepare": "husky install",
		"pullConfig": "vercel pull --yes --environment=production -t pRjJDDbIhqiLi7vNRjkIqxYe",
		"buildProd": "vercel build --prod",
		"desploy": "vercel deploy --prod --prebuilt  -t pRjJDDbIhqiLi7vNRjkIqxYe"
	},
	"prisma": {
		"schema": "db/schema.prisma"
	},
	"prettier": {
		"semi": false,
		"printWidth": 100
	},
	"lint-staged": {
		"*.{js,ts,tsx}": [
			"eslint --fix"
		]
	},
	"dependencies": {
		"@blitzjs/auth": "2.0.0-beta.4",
		"@blitzjs/next": "2.0.0-beta.4",
		"@blitzjs/rpc": "2.0.0-beta.4",
		"@prisma/client": "4.0.0",
		"blitz": "2.0.0-beta.4",
		"date-fns": "^2.29.3",
		"final-form": "4.20.7",
		"next": "12.2.5",
		"prisma": "4.0.0",
		"react": "18.2.0",
		"react-dom": "18.2.0",
		"react-final-form": "6.5.9",
		"react-markdown": "^8.0.3",
		"sass": "1.55.0",
		"zod": "3.17.3"
	},
	"devDependencies": {
		"@next/bundle-analyzer": "12.0.8",
		"@types/node": "17.0.16",
		"@types/preview-email": "2.0.1",
		"@types/react": "18.0.17",
		"@typescript-eslint/eslint-plugin": "5.30.5",
		"eslint": "7.32.0",
		"eslint-config-next": "12.2.0",
		"eslint-config-prettier": "8.5.0",
		"husky": "7.0.4",
		"lint-staged": "12.1.7",
		"pnp-webpack-plugin": "^1.7.0",
		"prettier": "^2.5.1",
		"prettier-plugin-prisma": "3.8.0",
		"pretty-quick": "3.1.3",
		"preview-email": "3.0.7",
		"typescript": "^4.5.3"
	},
	"private": true
}
